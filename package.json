{
  "name": "engraved",
  "version": "0.1.0",
  "author": "PzYon",
  "license": "ISC",
  "scripts": {
    "prepare": "husky",
    "knip": "knip",
    "prettier:check": "prettier --check \"**/*.{js,jsx,ts,tsx,css,scss,md,json,html}\"",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,css,scss,md,json,html}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,md,json}": [
      "npx prettier --write",
      "npx eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PzYon/engraved.git"
  },
  "bugs": {
    "url": "https://github.com/PzYon/engraved/issues"
  },
  "homepage": "https://github.com/PzYon/engraved#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tanstack/eslint-plugin-query": "5.101.1",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@types/node": "24.13.2",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "10.6.0",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "knip": "6.21.0",
    "lint-staged": "17.0.8",
    "prettier": "3.8.5",
    "typescript": "6.0.3"
  }
}
